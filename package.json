{
  "name": "scrypted-vigi",
  "version": "0.1.0",
  "description": "TP-Link VIGI two-way audio mixin plugin for Scrypted",
  "main": "src/main.ts",
  "scripts": {
    "build": "scrypted-webpack",
    "prepublishOnly": "npm run tsc && npm test",
    "scrypted-setup-project": "scrypted-setup-project",
    "prescrypted-setup-project": "scrypted-package-json",
    "scrypted-vscode-launch": "scrypted-deploy-debug",
    "prescrypted-vscode-launch": "scrypted-webpack",
    "scrypted-deploy-debug": "scrypted-deploy-debug",
    "scrypted-deploy": "scrypted-deploy",
    "scrypted-debug": "scrypted-debug",
    "scrypted-readme": "scrypted-readme",
    "scrypted-package-json": "scrypted-package-json",
    "test": "node --test -r ts-node/register test/*.test.ts",
    "tsc": "tsc --noEmit",
    "prepack": "NODE_ENV=production scrypted-webpack"
  },
  "keywords": [
    "scrypted",
    "plugin",
    "vigi",
    "tp-link",
    "camera",
    "intercom",
    "two-way-audio",
    "homekit"
  ],
  "scrypted": {
    "name": "VIGI Two Way Audio",
    "type": "DeviceProvider",
    "interfaces": [
      "DeviceProvider"
    ]
  },
  "dependencies": {
    "@scrypted/sdk": "latest",
    "crc-32": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "serialize-javascript": "^7.0.6"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanskardhanda/scrypted-vigi.git"
  },
  "bugs": {
    "url": "https://github.com/sanskardhanda/scrypted-vigi/issues"
  },
  "homepage": "https://github.com/sanskardhanda/scrypted-vigi#readme",
  "files": [
    "dist",
    "README.md"
  ]
}
