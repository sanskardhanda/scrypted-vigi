{
  "compilerOptions": {
    "outDir": "build",
    "module": "Node16",
    "target": "ES2021",
    "resolveJsonModule": true,
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ]
}
